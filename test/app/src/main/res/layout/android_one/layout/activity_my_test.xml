<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="zfl.myTest.myTest">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        tools:layout_editor_absoluteX="233dp"
        tools:layout_editor_absoluteY="16dp"
        tools:ignore="MissingConstraints">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="your name :"
                android:textSize="18dp" />

            <EditText
                android:id="@+id/test_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="please input your name" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="your password:"
                android:textSize="18dp" />

            <EditText
                android:id="@+id/test_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="please input ypur password" />
        </LinearLayout>

        <Button
            android:id="@+id/test_commit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="commit" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/test_getpicture"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="获取图片" />

            <TextView
                android:id="@+id/picturesuccess"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="正在获取图片。。。。"
                android:textSize="18dp"
                android:paddingLeft="50dp"
                />
        </LinearLayout>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <Button
                android:id="@+id/test_btn_post"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="带参上传图片"
                />
            <TextView
                android:id="@+id/test_postpicture"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="正在上传。。。。"
                android:textSize="18dp"
                android:paddingLeft="50dp"
                />

        </LinearLayout>

        <Button
        android:id="@+id/test_pay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="支付宝"
        />
        <Button
            android:id="@+id/test_Intent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="子线程跳转"
            />
    </LinearLayout>
</android.support.constraint.ConstraintLayout>
