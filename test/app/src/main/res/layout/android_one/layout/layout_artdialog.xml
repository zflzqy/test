<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="zfl.android_one.Artdialog">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <Button
            android:id="@+id/btn_dialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="普通" />
        <Button
            android:id="@+id/btn_dialog1"
            android:layout_below="@id/btn_dialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="单选" />
        <Button
            android:id="@+id/btn_dialog2"
            android:layout_below="@id/btn_dialog1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="多选" />
        <Button
            android:id="@+id/btn_dialog3"
            android:layout_below="@id/btn_dialog2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="列表" />
        <Button
        android:id="@+id/btn_dialog4"
        android:layout_below="@id/btn_dialog3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="自定义" />

    </RelativeLayout>
</android.support.constraint.ConstraintLayout>
