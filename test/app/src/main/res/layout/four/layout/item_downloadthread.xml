<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:id="@+id/tv_downloadthread"
        android:text="文件名"
        android:textSize="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />
    <ProgressBar
        android:id="@+id/thread_progress"
        android:layout_below="@id/tv_downloadthread"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="50dp" />
    <Button
        android:id="@+id/thread_stop"
        android:layout_alignParentRight="true"
        android:layout_below="@id/thread_progress"
        android:text="stop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
    <Button
        android:id="@+id/thread_start"
        android:layout_toLeftOf="@id/thread_stop"
        android:layout_below="@id/thread_progress"
        android:text="start"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
</RelativeLayout>
