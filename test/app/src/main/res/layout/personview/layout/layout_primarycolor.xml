<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    >
    <ImageView
        android:id="@+id/prim_image"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        />
    <SeekBar
        android:id="@+id/prim_seekbarhue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/prim_image"
        />
    <SeekBar
        android:id="@+id/prim_seekbarsaturation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/prim_seekbarhue"
        />
    <SeekBar
        android:id="@+id/prim_seekbarlum"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/prim_seekbarsaturation"
        />
</RelativeLayout>
